<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_beige"
    android:orientation="vertical">

    <!-- [LIBRARY HEADER] -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Library"
        android:textColor="@color/text_deep_brown"
        android:textSize="24sp"
        android:textStyle="bold"
        android:padding="20dp" />

    <!-- [OPTIONAL FILTERS - Styled Subtly] -->
    <LinearLayout
        android:id="@+id/filter_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginBottom="12dp">

        <Spinner
            android:id="@+id/spinner_subject"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/bg_white_rounded"
            android:layout_marginEnd="8dp"
            android:elevation="2dp" />

        <Spinner
            android:id="@+id/spinner_topic"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/bg_white_rounded"
            android:elevation="2dp" />
    </LinearLayout>

    <!-- [FILES LIST] -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_files"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:clipToPadding="false" />

    <!-- [BOTTOM ACTIONS BAR] -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center"
        android:background="@color/surface_white">

        <Button
            android:id="@+id/btn_new_folder"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:text="New Folder"
            android:layout_marginEnd="6dp"
            app:icon="@android:drawable/ic_input_add"
            app:iconGravity="top"
            app:iconSize="24dp"
            android:textColor="@color/primary_brown"
            app:strokeColor="@color/primary_brown"
            android:textAllCaps="false"
            android:textSize="11sp"
            android:padding="4dp" />

        <Button
            android:id="@+id/btn_upload"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:text="Upload"
            android:layout_marginEnd="6dp"
            app:icon="@android:drawable/stat_sys_upload"
            app:iconGravity="top"
            app:iconSize="24dp"
            android:textColor="@color/primary_brown"
            app:strokeColor="@color/primary_brown"
            android:textAllCaps="false"
            android:textSize="11sp"
            android:padding="4dp" />

        <Button
            android:id="@+id/btn_start_quiz"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:text="Start Quiz"
            app:icon="@android:drawable/ic_menu_help"
            app:iconGravity="top"
            app:iconSize="24dp"
            android:backgroundTint="@color/card_study_green"
            android:textColor="@color/white"
            android:textAllCaps="false"
            android:textSize="11sp"
            android:textStyle="bold"
            android:padding="4dp" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</LinearLayout>
